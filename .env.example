# AICortex — copy this file to `.env` and adjust. Never commit `.env`.

# Host port the connector is published on.
# (The container always listens on 8787 internally; this only sets the host mapping.)
HOST_PORT=8787

# Address the published port is bound to. Default 127.0.0.1 = only THIS host (your
# reverse proxy) can reach the connector — NOT the whole LAN, so nobody hits /mcp or
# /hooks/* past the proxy. A host-network proxy (e.g. Zoraxy in host mode) sees
# 127.0.0.1 fine. If your reverse proxy runs as a SEPARATE bridge-network container,
# set 0.0.0.0 (or put both on a shared Docker network), or it can't reach /mcp.
BIND_ADDR=127.0.0.1

# Run the container process as this user/group — match your NAS user!
# Find yours with:  id <username>
PUID=1000
PGID=1000

# Container timezone
TZ=UTC

# ── Authentication (recommended before exposing publicly) ──────────────
# Protect the connector with OAuth 2.1 via your own OIDC provider
# (Pocket ID, Authentik, Keycloak, Auth0, …). If left blank the server binds to
# 127.0.0.1 ONLY (local) — set ALLOW_INSECURE=1 below to force an open bind.
# NOTE: any account that can log in to your IdP gets FULL access to all tools and
# data — point this at a single-user / dedicated provider, not a shared one.
# Register a client in your provider with redirect URI:  <BASE_URL>/auth/callback
# OIDC_CONFIG_URL=https://id.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# BASE_URL=https://agent.example.com
# JWT_SIGNING_KEY=        # generate with: openssl rand -hex 32
# STORAGE_ENCRYPTION_KEY= # encrypts BOTH the OAuth client store (data/auth) AND
#                         # the secret vault (data/vault). Required for secret_set —
#                         # it refuses to store plaintext without it.
#                         # generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"

# ── Hardening (secure defaults; tune to taste) ─────────────────────────
# SSRF allow-list for call_service / mqtt / ftp. EMPTY = block all private &
# link-local targets (cloud metadata, LAN panels). Set the subnets you actually
# use — LAN and/or VPN — so your own devices keep working:
# INTERNAL_ALLOW_CIDRS=192.168.1.0/24,100.64.0.0/10
# Which source IPs may set X-Forwarded-* (default "*"). Tighten to your proxy:
# FORWARDED_ALLOW_IPS=*
# Escape hatches (leave unset for the secure defaults):
# ALLOW_INSECURE=1         # allow an open 0.0.0.0 bind when no OIDC is set
# ALLOW_PLAINTEXT_VAULT=1  # allow secret_set without an encryption key
# Static token for headless machine clients (the autonomy runner — any LLM).
# When set, the connector accepts it ALONGSIDE OIDC (MultiAuth). The runner uses
# the same value. Generate: openssl rand -hex 32
# RUNNER_TOKEN=

# ── Authorization (least-privilege roles; ON by default) ───────────────
# The policy gate enforces roles (admin | user | viewer) out of the box: the
# RUNNER_TOKEN is a non-admin "user" (can't register services/MCP/cron or set
# secrets), while an interactive OIDC operator is "admin" (no lockout). Denials
# are logged to data/auth/audit.log. Disable enforcement entirely with:
# AUTH_ENFORCE=0
# Override the default roles:
# RUNNER_ROLE=user
# OIDC_DEFAULT_ROLE=admin
# Drive roles from an IdP role/group claim (e.g. Pocket ID groups). The built-in
# PocketID-aware proxy forwards the upstream sub/groups, so this works end-to-end.
# Request the groups in the login scope, then map groups→roles in policy.json:
# OIDC_SCOPE=openid profile email groups
# AUTH_ROLE_CLAIM=groups
# Also log allowed calls (full audit), not just denials:
# AUTH_AUDIT_ALL=1
# Per-identity roles + group→role map live in data/auth/policy.json:
#   {"roles": {"<id>": "viewer"}, "groups": {"AICortex-Admins": "admin"},
#    "runner": "user", "default": "admin"}

# ── Per-user data isolation & capability areas (multi-tenant) ──────────
# Rides on AUTH_ENFORCE above (one switch — "enforce means enforce"; no separate
# TENANCY_ISOLATE). With AUTH_ENFORCE=1 each non-admin is confined to their OWN
# memory scope (users/<sub>) and private vault namespace so two people on one brain
# don't read/overwrite each other, AND reaches only the services/skills an admin
# assigns (default-deny). Admins keep full access; admins provision per-user secrets
# with secret_set owner=<sub>. Manage areas with the tenancy_* tools or policy.json.
# policy.json example:
#   {"users": {"<sub>": {"memory": "own", "vault": "own",
#                        "services": ["github"], "skills": "all"}}}   # "all" widens, "none" locks out

# ── Native REST API (v1.9.0) ───────────────────────────────────────────
# A plain-HTTP layer next to /mcp so non-MCP clients (n8n, LangChain, scripts, any
# OpenAI-compatible / function-calling framework) can call AICortex tools with a
# per-user API key:
#   GET  /api/v1/tools · POST /api/v1/tools/<name> · GET /api/v1/openapi.json
# Keys are minted by an admin (apikey_create), default-deny + per-key scoped, and run
# through the SAME per-user areas as OIDC (never admin by default). Like /hooks/*,
# expose /api/* past the reverse proxy WITHOUT OIDC — never expose /mcp that way.
# On by default; turn the whole REST layer off with:
# API_ENABLED=0
# Per-key rate limit (requests per minute; 0 = unlimited):
# API_RATE_PER_MIN=60
# Max request body for a single tool call (bytes):
# API_MAX_BODY_BYTES=1000000

# ── Mail policy ────────────────────────────────────────────────────────
# Restrict who mail_send may email (comma list of addresses, @domains or domains).
# Unset = unrestricted. Also: MAIL_MAX_ATTACH_BYTES caps attachment size (default 25MB).
# MAIL_ALLOWED_RECIPIENTS=@example.com, boss@corp.com

# ── Other secrets (used as features land; stay on your NAS) ────────────
# Real credentials go here and are used server-side only. Examples:
# HA_URL=
# HA_TOKEN=
